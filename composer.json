        "ext-imagick": "*",
        "psr/log": "*",
        "spatie/regex": "^1.4",
        "symfony/var-dumper": "^5.3",
        "karelwintersky/arris": "^2",
        "karelwintersky/arris.router": "^2",
        "karelwintersky/arris.delight-php-auth": "^0.99",
        "karelwintersky/arris.database": "^2",
        "karelwintersky/arris.entity": "^1",
        "karelwintersky/arris.cache": "^1",
        "karelwintersky/arris.logger": "^2",
        "karelwintersky/arris.toolkit.cli-console": "^1.3",
        "karelwintersky/arris.presenter": "^1.0",
        "ajur-media/kcaptcha": "^1.1",
        "mobiledetect/mobiledetectlib": "^3.74",
        "kuria/error": "^4.2",
